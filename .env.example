# =========================
# SuCash project environment template
# Copy this file to `.env` and fill secrets locally.
# Never commit real secrets.
# =========================

# Server bind config
SUCASH_SERVER_HOST=0.0.0.0
SUCASH_SERVER_PORT=8080

# Local SQLite DB fallback (used when TURSO_DATABASE_URL is empty)
SUCASH_SERVER_DB_PATH=data/sucash-server.db

# Turso credentials (when set, server uses Turso/libSQL as primary DB)
TURSO_DATABASE_URL=libsql://your-db-name.region.turso.io
TURSO_AUTH_TOKEN=
SUCASH_MIGRATE_LOCAL_SQLITE_TO_TURSO=false
# Optional source path for one-time migration when flag above is true.
SUCASH_MIGRATION_SOURCE_DB_PATH=data/sucash-server.db

# Optional mobile defaults (manual app settings still apply)
SUCASH_DEFAULT_OUTLET_ID=default
SUCASH_DEFAULT_SERVER_BASE_URL=http://10.0.2.2:8080

# Shared secret for protected write APIs
# Mobile/web derive opaque bearer from active role + PIN + this secret.
SUCASH_API_SHARED_SECRET=
